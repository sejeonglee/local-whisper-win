{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WhisperWindows",
  "version": "0.1.0",
  "identifier": "com.sejeonglee.whisperwindows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run prepare:sidecar-runtime && npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WhisperWindows",
        "width": 520,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/.python-runtime/": "sidecar/python/",
      "../sidecar/.venv/Lib/site-packages/": "sidecar/site-packages/",
      "../sidecar/src/": "sidecar/src/"
    },
    "targets": "all"
  }
}
