{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WhisperWindows",
  "version": "0.1.0",
  "identifier": "com.sejeonglee.whisperwindows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run prepare:sidecar-runtime && npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WhisperWindows",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": [
          "windows/cleanup.wxs"
        ],
        "componentGroupRefs": [
          "CleanupAppDataGroup"
        ]
      }
    },
    "resources": {
      "../sidecar/.python-runtime/": "sidecar/python/",
      "../sidecar/src/": "sidecar/src/"
    },
    "targets": "all"
  }
}
